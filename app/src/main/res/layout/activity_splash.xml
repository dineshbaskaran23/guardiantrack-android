<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:background="#0A1628" android:padding="32dp">
    <ImageView android:layout_width="80dp" android:layout_height="80dp"
        android:src="@drawable/ic_shield" android:layout_marginBottom="16dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="GuardianTrack" android:textColor="#E8F0FE"
        android:textSize="26sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Protecting your loved ones" android:textColor="#7A90B0"
        android:textSize="14sp" android:layout_marginBottom="32dp"/>
    <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:indeterminateTint="#00C9A7"/>
</LinearLayout>
